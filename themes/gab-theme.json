{
  "name": "GAB Theme",
  "type": "dark",
  "colors": {
    "editor.background": "#1f1f1f",
    "editor.foreground": "#d4d4d4",
    "editorCursor.foreground": "#ffffff",
    "editor.lineHighlightBackground": "#2a2a2a",
    "editor.selectionBackground": "#264f78"
  },
  "tokenColors": [
    {
      "scope": "comments",
      "settings": {
        "foreground": "#6a9955"
      }
    },
    {
      "scope": "strings",
      "settings": {
        "foreground": "#d48220"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#2938d9"
      }
    },
    {
      "scope": "namespaces",
      "settings": {
        "foreground": "#2a7d2e"
      }
    },
    {
      "scope": "namespaces.variables",
      "settings": {
        "foreground": "#2a7d2e"
      }
    }
  ]
}