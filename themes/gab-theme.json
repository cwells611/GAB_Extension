{
  "name": "GAB Theme",
  "type": "dark",
  "colors": {
    "editor.background": "#2b2b2b",
    "editor.foreground": "#d4d4d4",
    "editorCursor.foreground": "#ffffff",
    "editor.lineHighlightBackground": "#2a2a2a",
    "editor.selectionBackground": "#264f78"
  },
  "tokenColors": [
    {
      "scope": "comments",
      "settings": {
        "foreground": "#57a64b"
      }
    },
    {
      "scope": "strings",
      "settings": {
        "foreground": "#d69d82"
      }
    },
    {
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#2938d9"
      }
    },
    {
      "scope": "namespaces",
      "settings": {
        "foreground": "#4ec9b0"
      }
    },
    {
      "scope": "namespaces.variables",
      "settings": {
        "foreground": "#4ec9b0"
      }
    }
  ]
}